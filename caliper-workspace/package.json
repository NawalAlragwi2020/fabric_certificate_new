{
  "name": "bcms-caliper-workspace",
  "version": "3.0.0",
  "description": "BCMS Certificate Benchmark — Hyperledger Caliper v3.0",
  "scripts": {
    "benchmark": "caliper launch manager --caliper-workspace . --caliper-benchconfig benchconfig.yaml --caliper-networkconfig networkConfig.yaml --caliper-fabric-gateway-enabled",
    "bind": "caliper bind --caliper-bind-sut fabric:fabric-gateway",
    "clean": "rm -rf node_modules package-lock.json report*.html .caliper"
  },
  "dependencies": {
    "@hyperledger/caliper-cli": "0.6.0",
    "@hyperledger/caliper-fabric": "0.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "private": true
}
